---
import Layout from '../layouts/Layout.astro';
import { commonData } from '../data/common.js';
import { contactData } from '../data/contact.js';

const url = new URL(Astro.request.url);
const currentLang = (url.searchParams.get('lang') || 'de') as keyof typeof contactData;

// Daten für die gewählte Sprache laden
const t = contactData[currentLang] || contactData.de;
const common = commonData[currentLang] || commonData.de;


const channels = [
  { icon: '✉', label: 'E-Mail', value: 'aresd.public@gmail.com', href: 'mailto:aresd.public@gmail.com' },
  { icon: '⌥', label: 'GitHub', value: 'github.com/AresAndStuff', href: common.socialLinks.github },
  { icon: '◈', label: 'LinkedIn', value: 'linkedin.com/in/ares-dovalo-b07a3224b', href: common.socialLinks.linkedin },
];
---
<Layout title={`${t.label}${common.meta.titleSuffix}`}>
  <main class="page">
    <section class="section-hero">
      <div class="label">{t.label}</div>
      <h1 style="max-width: 480px;">
        {t.titleBefore}<em class="accent">{t.titleAccent}</em>.
      </h1>
      <p style="max-width: 50ch;">{t.desc}</p>
    </section>

    <div class="grid-cols" style="margin-bottom: 3rem;">
      {channels.map(c => (
        <a href={c.href} style="text-decoration: none; color: inherit;" target="_blank" rel="noopener">
          <div class="card" style="height: 100%; display: flex; flex-direction: column; gap: 0.5rem;">
            <div style="font-size: 26px; color: var(--accent); margin-bottom: 0.5rem;">{c.icon}</div>
            <div style="font-family: var(--mono); font-size: 12px; color: var(--text-lo); text-transform: uppercase; letter-spacing: 0.1em;">{c.label}</div>
            <div style="font-size: 16px; font-weight: 700; color: var(--text-hi); word-break: break-all;">{c.value}</div>
          </div>
        </a>
      ))}
    </div>

    <div class="card" style="border-left: 3px solid var(--accent) !important; padding: 1.5rem 2rem; margin-bottom: 6rem;">
      <p style="margin: 0; font-size: 15px;">
        <strong style="color: var(--accent); font-family: var(--mono); font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 0.5rem;">{t.replyTitle}</strong>
        {t.replyText}
      </p>
    </div>
  </main>
</Layout>