---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    num: '01',
    name: 'NixOS Konfiguration',
    status: 'Aktiv',
    stack: ['Nix', 'Linux', 'Flakes', 'Home Manager'],
    desc: 'Ein vollständig deklaratives Linux-System — Nix-Flakes für reproduzierbare Builds, Home Manager für dotfiles, alles versioniert in Git. Das Ziel: ein System das sich auf jeder Maschine identisch aufbaut, ohne manuelle Schritte.',
    links: [{ label: 'GitHub', href: '#' }],
  },
  {
    num: '02',
    name: 'Sorting Visualizer',
    status: 'Abgeschlossen',
    stack: ['JavaScript', 'HTML/CSS', 'Algorithmen'],
    desc: 'Browser-Applikation die klassische Sortieralgorithmen (Bubble Sort, Merge Sort, Quick Sort, Insertion Sort) in Echtzeit animiert. Jeder Vergleich und jeder Swap ist sichtbar — ideal zum Verstehen der Komplexität.',
    links: [{ label: 'Demo', href: '#' }, { label: 'GitHub', href: '#' }],
  }
];
---
<Layout title="Projekte | Pascal">
  <main class="page">
    <section class="section-hero">
      <div class="label">Ausgewählte Arbeiten</div>
      <h1>Meine <em class="accent">Projekte</em></h1>
      <p>Was ich gebaut habe — und warum.</p>
    </section>

    <div class="stack-list">
      {projects.map(p => (
        <article class="card">
          <div style="display: flex; gap: 10px; align-items: center; margin-bottom: 0.75rem;">
            <span style="font-family: var(--mono); font-size: 11px; color: var(--text-lo);">{p.num}</span>
            <span class="tag tag-accent">{p.status}</span>
          </div>
          <h3>{p.name}</h3>
          <p>{p.desc}</p>
          <div class="inline-tags">
            {p.stack.map(t => <span class="tag">{t}</span>)}
          </div>
          <div class="btn-links">
            {p.links.map(l => <a href={l.href} class="btn-ghost">{l.label} →</a>)}
          </div>
        </article>
      ))}
    </div>
  </main>
</Layout>