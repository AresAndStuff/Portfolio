---
import Layout from '../layouts/Layout.astro';
import { projectsData } from '../data/projects.js';

const url = new URL(Astro.request.url);

const currentLang = (url.searchParams.get('lang') || 'de') as keyof typeof projectsData;
const data = projectsData[currentLang] || projectsData.de;
---
<Layout title={data.title}>
  <main class="page">
    <section class="section-hero">
      <div class="label">{data.heroLabel}</div>
      <h1>{data.heroTitle}<em class="accent">{data.heroAccent}</em></h1>
      <p>{data.heroDesc}</p>
    </section>

    <div class="stack-list">
      {data.items.map(p => (
        <article class="card">
          <div style="display: flex; gap: 10px; align-items: center; margin-bottom: 0.75rem;">
            <span style="font-family: var(--mono); font-size: 11px; color: var(--text-lo);">{p.num}</span>
            <span class="tag tag-accent">{p.status}</span>
          </div>
          <h3>{p.name}</h3>
          <p>{p.desc}</p>
          <div class="inline-tags">
            {p.stack.map(t => <span class="tag">{t}</span>)}
          </div>
          <div class="btn-links">
            {p.links.map(l => <a href={l.href} class="btn-ghost">{l.label} →</a>)}
          </div>
        </article>
      ))}
    </div>
  </main>
</Layout>