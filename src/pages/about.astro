---
import Layout from '../layouts/Layout.astro';
import { commonData } from '../data/common';
import { aboutData } from '../data/about';

const url = Astro.url;
const currentLang = ['en', 'es'].includes(url.searchParams.get('lang') || '') 
  ? url.searchParams.get('lang') as 'en' | 'es' 
  : 'de';

const data = aboutData[currentLang] || aboutData.de;
const common = commonData[currentLang] || commonData.de;

// Dynamische Timeline basierend auf der Sprache erstellen
const timeline = [
  { year: '2025 →', event: data.timelineEvents.zhaw },
  { year: '2025', event: data.timelineEvents.bms },
  { year: '2021–2025', event: data.timelineEvents.efz },
];
---
<Layout title={`${data.label}${common.meta.titleSuffix}`}>
  <main class="page">
    <section class="section-hero">
      <div class="label">{data.label}</div>
      <h1>
        {data.titleBefore}<br>
        {data.titleMiddle}<br>
        {data.titleAfter}<em class="accent">{data.titleAccent}</em>.
      </h1>
      <p style="max-width: 50ch; font-size: 14px;">{data.desc}</p>
    </section>

    <hr />

    <section style="margin-bottom: 4rem;">
      <h2>{data.historyTitle}</h2>
      <ul class="timeline">
        {timeline.map(item => (
          <li class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-year">{item.year}</div>
            <div class="timeline-title">{item.event}</div>
          </li>
        ))}
      </ul>
    </section>

    <hr />

    <section style="margin-bottom: 4rem;">
      <h2>{data.skillsTitle}</h2>
      <div class="grid-cols">
        {data.skills.map(s => (
          <div class="card">
            <div class="label" style="margin-bottom: 1rem;">{s.cat}</div>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
              {s.items.map(item => (
                <li style="font-family: var(--mono); font-size: 12px; color: var(--text-mid); display: flex; align-items: center; gap: 0.5rem;">
                  <span style="color: var(--accent); font-size: 10px;">▸</span>{item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="card" style="margin-bottom: 6rem;">
      <h2 style="margin-bottom: 1rem;">{data.privateTitle}</h2>
      <p style="margin-bottom: 0; max-width: 50ch;">{data.privateDesc}</p>
    </section>
  </main>
</Layout>